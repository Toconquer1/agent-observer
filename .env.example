# Anthropic API Configuration for LLM Analysis
# Copy this file to .env and fill in your values

# Required: Your Anthropic API key
ANTHROPIC_API_KEY=your_api_key_here

# Optional: Custom API URL (defaults to https://api.anthropic.com)
# Use this if you're using a compatible API endpoint
ANTHROPIC_API_URL=https://api.anthropic.com
