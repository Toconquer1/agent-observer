# agent-observer LLM Analysis Configuration
# Copy this file to the project root .env and fill in your values
#
# All variables use the AGOB_ prefix to avoid conflicts with other applications.

# Required: Your API key
AGOB_API_KEY=your_api_key_here

# Optional: Custom API URL (defaults to https://api.anthropic.com)
# Use this if you're using a compatible API endpoint (e.g. DeepSeek, OpenRouter)
AGOB_API_URL=https://api.anthropic.com

# Optional: Model to use for analysis (defaults to claude-sonnet-4-6)
AGOB_MODEL=claude-sonnet-4-6
